# Environment Configuration Template
# Copy this to .env and fill in your values for production

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your_secret_key_here

# Server Configuration
HOST=0.0.0.0
PORT=5000

# File Upload Configuration
MAX_FILE_SIZE=16777216
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS=csv,txt

# Database Configuration (Future)
# DATABASE_URL=db2+pyodbc://username:password@hostname:1433/database_name
# COBOL_DATABASE_HOST=your_db2_host
# COBOL_DATABASE_PORT=50000

# Message Queue Configuration (Future - for COBOL integration)
# RABBITMQ_URL=amqp://username:password@localhost:5672/
# KAFKA_BROKER=localhost:9092
# QUEUE_NAME=validation_queue

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Security Configuration (Production)
# CORS_ORIGINS=https://yourdomain.com
# API_KEY_SECRET=your_api_key_secret

# Feature Flags
ENABLE_DATABASE_INTEGRATION=False
ENABLE_COBOL_INTEGRATION=False
ENABLE_ADVANCED_LOGGING=False
